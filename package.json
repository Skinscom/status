{
  "name": "skinscom-status",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "vue-tsc --noEmit",
    "generate:data": "node scripts/build-data.mjs",
    "sync:incidents": "node scripts/sync-incidents.mjs",
    "monitor": "node scripts/update-monitoring.mjs",
    "build": "npm run typecheck && npm run generate:data && vite build && node scripts/postbuild.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource-variable/ibm-plex-sans": "5.2.8",
    "@fontsource/ibm-plex-mono": "5.2.7",
    "lucide-vue-next": "0.547.0",
    "vue": "3.5.13",
    "vue-router": "4.5.1"
  },
  "devDependencies": {
    "@types/node": "24.3.0",
    "@vitejs/plugin-vue": "6.0.1",
    "sass": "1.89.2",
    "typescript": "5.9.2",
    "vite": "7.1.3",
    "vue-tsc": "3.0.5"
  }
}
